{
  "serviceId": "cicd-workflow",
  "name": "CI/CD Workflow Backend",
  "serviceType": "tribe",
  "baseUrl": "http://localhost:4000",
  "requiredScopes": [
    "cicd:project:read",
    "cicd:project:write",
    "cicd:workflow:read",
    "cicd:workflow:write"
  ],
  "exposes": [
    "/api/v1/auth",
    "/api/v1/catalog",
    "/api/v1/subscription",
    "/api/v1/workflows",
    "/api/v1/health"
  ],
  "consumes": ["payment", "gauth"],
  "healthCheck": "/api/v1/health",
  "version": "1.0.0",
  "description": "CI/CD Workflow backend — GitHub Actions pipeline provisioning and workflow management SaaS"
}
