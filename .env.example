# =============================================================================
# Environment Variable Reference — Sensitivity Classification
# =============================================================================
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# Store HIGH-sensitivity values in GitHub Secrets / Vault / your cloud
# provider's secret manager — not in plaintext files on developer machines.
#
# Sensitivity levels used here:
#   LOW    — safe to log, share in tickets, or store unencrypted in CI env vars
#   MEDIUM — treat like a password: do not log, rotate on breach, but not a
#             root credential
#   HIGH   — treat like a private key: store in Vault/Secrets Manager, rotate
#             immediately on breach, never pass as a CLI argument or log
#
# =============================================================================

# -----------------------------------------------------------------------------
# Service identity
# NODE_ENV       — LOW sensitivity
#                  Controls framework behaviour (error verbosity, Swagger, etc.)
#                  Values: development | test | production
# -----------------------------------------------------------------------------
NODE_ENV=development

# SESSION_SECRET — HIGH sensitivity
#                  Secret used to sign the session cookie. Must be at least
#                  32 characters. Generate a strong value with:
#                  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#                  Store in Vault / GitHub Secrets — never commit the real value.
SESSION_SECRET=replace-me-with-at-least-32-character-secret-value

# PORT           — LOW sensitivity
#                  TCP port the HTTP server binds to inside the container.
#                  The container port is remapped by the orchestrator; this
#                  value is not externally visible.
# -----------------------------------------------------------------------------
PORT=4000

# ENABLE_SWAGGER — LOW sensitivity
#                  Set to true ONLY in development/local environments.
#                  Swagger UI exposes full API schema — never enable in prod.
# -----------------------------------------------------------------------------
ENABLE_SWAGGER=false

# -----------------------------------------------------------------------------
# Supabase
# SUPABASE_URL              — LOW sensitivity
#                             Public HTTPS endpoint for your Supabase project.
#                             Visible in Supabase dashboard Settings > API.
# SUPABASE_ANON_KEY         — MEDIUM sensitivity
#                             JWT signed with the project's anon role. Safe for
#                             server-side use because RLS policies apply. Do not
#                             expose to end-user browsers from this service.
# SUPABASE_SERVICE_ROLE_KEY — HIGH sensitivity
#                             Bypasses all Row Level Security. Full database
#                             access with no restrictions. Store in Vault or
#                             GitHub Secrets — never in a .env file committed
#                             to any repository.
#
# Optional service-scoped Supabase clients for microservice/tribe routing:
#   <SERVICE>_SUPABASE_URL
#   <SERVICE>_SUPABASE_SECRET_KEY
# or
#   <SERVICE>_SUPABASE_SERVICE_ROLE_KEY
#
# Examples:
#   PAYMENT_SERVICE_SUPABASE_URL=https://payment-project.supabase.co
#   PAYMENT_SERVICE_SUPABASE_SECRET_KEY=payment-service-role-key
#   CHAT_SERVICE_SUPABASE_URL=https://chat-project.supabase.co
#   CHAT_SERVICE_SUPABASE_SECRET_KEY=chat-service-role-key
#
# Each scoped service must define both URL + secret key to be activated.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# CORS
# ALLOWED_ORIGINS — LOW sensitivity
#                   Comma-separated list of browser origins permitted to call
#                   this API. Example: http://localhost:5173,https://app.example.com
#                   No wildcard (*) is accepted — the CORS factory enforces
#                   exact-match whitelisting.
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# AlphaCI frontend, backend callback origin, and workflow template source
# FRONTEND_URL          — LOW sensitivity
#                         Browser URL for the active Next.js portal. Used for
#                         OAuth redirects after login.
# PLATFORM_PUBLIC_URL   — LOW sensitivity
#                         Public backend origin used in generated CI callback
#                         URLs. May include or omit /api/v1.
#                         If unset, generated workflows derive it from
#                         GITHUB_CALLBACK_URL.
# TEMPLATE_REPO_PATH    — LOW sensitivity
#                         Local path to the central workflow engine repository.
# TEMPLATE_WORKFLOW_DIR — LOW sensitivity
#                         Directory inside TEMPLATE_REPO_PATH containing
#                         renderable workflow templates.
# CENTRAL_WORKFLOW_REF  — LOW sensitivity
#                         Git ref (tag/branch) of the central reusable workflows
#                         that generated pipelines pin to
#                         (cicd-external-project/cicd-workflow). The external
#                         (sold) deployment uses `v1`. The INTERNAL Alphaexplora
#                         deployment sets this to `internal-v1` so its pipelines
#                         track a separate, independently-versioned tag and never
#                         collide with the customer-facing `v1` line. Per-project
#                         overrides still take precedence. Default: v1
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
PLATFORM_PUBLIC_URL=http://localhost:4000
TEMPLATE_REPO_PATH=../cicd-workflow
TEMPLATE_WORKFLOW_DIR=workflow-templates
CENTRAL_WORKFLOW_REF=v1

# -----------------------------------------------------------------------------
# Payments
# PAYMENT_PROVIDER       LOW sensitivity
#                        Values: none | paymongo. Use paymongo for hosted checkout.
# PAYMONGO_SECRET_KEY    HIGH sensitivity
#                        PayMongo secret API key. Store in Vault / GitHub Secrets.
# PAYMONGO_WEBHOOK_SECRET HIGH sensitivity
#                        PayMongo webhook signing secret when webhook fulfillment is enabled.
# PAYMENT_SUCCESS_URL    LOW sensitivity
#                        Frontend URL PayMongo returns to after successful checkout.
# PAYMENT_CANCEL_URL     LOW sensitivity
#                        Frontend URL PayMongo returns to after checkout cancellation.
# PRO_MONTHLY_PRICE_PHP  LOW sensitivity
#                        Pro Monthly amount in Philippine pesos.
# -----------------------------------------------------------------------------
PAYMENT_PROVIDER=paymongo
PAYMONGO_SECRET_KEY=sk_test_replace_me
PAYMONGO_WEBHOOK_SECRET=whsec_replace_me
PAYMENT_SUCCESS_URL=http://localhost:3000/subscribe?status=success
PAYMENT_CANCEL_URL=http://localhost:3000/subscribe?status=cancelled
PRO_MONTHLY_PRICE_PHP=300

# -----------------------------------------------------------------------------
# Environment provisioning (feature flagged)
# ENV_PROVISIONING_ENABLED        LOW sensitivity
#                                 Set true to expose provider/env provisioning UI
#                                 and API routes.
# ENV_PROVISIONING_OWNERSHIP_MODE LOW sensitivity
#                                 Deployment ownership model this deployment
#                                 offers. 'byo' (default) = users connect their
#                                 own Render/Vercel accounts (external/sold
#                                 product). 'flowci_managed' = deployments are
#                                 centralized on the ORGANIZATION's Render/Vercel
#                                 via the FLOWCI_* credentials below (internal
#                                 Alphaexplora deployment); BYO is not offered.
# ENV_PROVISIONING_ENCRYPTION_KEY HIGH sensitivity
#                                 Base64-encoded 32-byte key used to encrypt BYO
#                                 Render/Vercel provider tokens at rest.
#                                 Generate with:
#                                 node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# FLOWCI_RENDER_API_KEY           HIGH sensitivity
#                                 FlowCI-managed Render API key. Required only
#                                 when using flowci_managed Render targets.
# FLOWCI_RENDER_OWNER_ID          LOW sensitivity
#                                 FlowCI-managed Render workspace id used when
#                                 creating services. Starts with tea-. Required
#                                 for deterministic FlowCI-managed Render
#                                 project creation.
# FLOWCI_RENDER_DEFAULT_REGION    LOW sensitivity
#                                 Default Render region for managed services.
# FLOWCI_RENDER_DEFAULT_INSTANCE_TYPE LOW sensitivity
#                                 Default managed Render instance. Use free
#                                 unless paid managed provisioning is approved.
# FLOWCI_RENDER_ALLOWED_INSTANCE_TYPES LOW sensitivity
#                                 Comma-separated managed allowlist.
# FLOWCI_RENDER_ALLOW_PAID_MANAGED LOW sensitivity
#                                 Set true only after managed billing controls
#                                 and quotas are approved.
# FLOWCI_RENDER_MANAGED_MAX_SERVICES_PER_USER LOW sensitivity
#                                 Managed Render quota guard.
# FLOWCI_RENDER_BOOTSTRAP_IMAGE   LOW sensitivity
#                                 Initial image used before GitHub Actions
#                                 pushes the project image.
# FLOWCI_RENDER_REGISTRY_CREDENTIAL_ID MEDIUM sensitivity
#                                 Render registry credential id for private
#                                 GHCR image pulls.
# FLOWCI_VERCEL_TOKEN             HIGH sensitivity
#                                 FlowCI-managed Vercel token. Required only
#                                 when using flowci_managed Vercel targets.
# FLOWCI_VERCEL_TEAM_ID           MEDIUM sensitivity
#                                 Optional Vercel team id for FlowCI-managed use.
# FLOWCI_VERCEL_TEAM_SLUG         LOW sensitivity
#                                 Optional Vercel team slug for display/routing.
# -----------------------------------------------------------------------------
ENV_PROVISIONING_ENABLED=false
ENV_PROVISIONING_OWNERSHIP_MODE=byo
ENV_PROVISIONING_ENCRYPTION_KEY=
FLOWCI_RENDER_API_KEY=
FLOWCI_RENDER_OWNER_ID=
FLOWCI_RENDER_DEFAULT_REGION=singapore
FLOWCI_RENDER_DEFAULT_INSTANCE_TYPE=free
FLOWCI_RENDER_ALLOWED_INSTANCE_TYPES=free
FLOWCI_RENDER_ALLOW_PAID_MANAGED=false
FLOWCI_RENDER_MANAGED_MAX_SERVICES_PER_USER=2
FLOWCI_RENDER_BOOTSTRAP_IMAGE=docker.io/library/nginx:alpine
FLOWCI_RENDER_REGISTRY_CREDENTIAL_ID=
FLOWCI_VERCEL_TOKEN=
FLOWCI_VERCEL_TEAM_ID=
FLOWCI_VERCEL_TEAM_SLUG=

# -----------------------------------------------------------------------------
# GitHub OAuth (required for GitHub login)
#
# GITHUB_CLIENT_ID     — MEDIUM sensitivity
#                        OAuth App client ID from GitHub Settings > Developer settings.
# GITHUB_CLIENT_SECRET — HIGH sensitivity
#                        OAuth App client secret. Store in Vault / GitHub Secrets.
# GITHUB_CALLBACK_URL  — LOW sensitivity
#                        Must match the Authorization callback URL registered in your
#                        GitHub OAuth App settings.
# GITHUB_SCOPE         — LOW sensitivity
#                        Comma- or space-separated GitHub OAuth scopes. The product
#                        creates repos (needs `repo`) and pushes workflow files
#                        (needs `workflow`). Internal-org gating additionally needs
#                        `read:org` to read the signed-in user's org membership.
#                        Default: repo,workflow,read:org
# GITHUB_INTERNAL_ORG  — LOW sensitivity
#                        Login of the internal company GitHub org. When SET, this
#                        deployment becomes the INTERNAL workspace: members of this
#                        org are marked internal (is_internal=true) and bypass the
#                        subscription/payment gate; NON-members are hard-blocked at
#                        login. Leave EMPTY on the external (sold) deployment to
#                        disable internal gating entirely. Example: my-company-org
# GITHUB_ENFORCED_ORG  — LOW sensitivity
#                        Login of the org that EVERY created repository must
#                        belong to. When set, the product always creates repos
#                        in this org (never in personal accounts); ownerType /
#                        installationId on the request are ignored. Requires the
#                        GitHub App installed on this org with access to ALL
#                        repositories, and the signed-in user to be a member.
#                        Defaults to "Alpha-Explora" when unset — set to an
#                        EMPTY string to restore per-request owner choice.
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback
GITHUB_SCOPE=repo,workflow,read:org
GITHUB_INTERNAL_ORG=
GITHUB_ENFORCED_ORG=Alpha-Explora
ARCHIVED_ACCOUNT_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Outbox processor (process-outbox.ts / Render Cron Job)
#
# SUPABASE_DB_URL      — HIGH sensitivity
#                        "Direct" Postgres connection string (port 5432, NOT the
#                        PgBouncer/Supavisor pooler on port 6543). The outbox
#                        processor uses SELECT FOR UPDATE which requires a real
#                        connection. Format: postgres://postgres:<password>@<host>:5432/postgres
#
#                        NOTE: on this project, port 5432 is itself proxied
#                        through Supavisor in session mode (Supabase now routes
#                        most "direct" hostnames through Supavisor rather than
#                        raw Postgres) — Postgres logs show every connection
#                        authenticating as `pgbouncer`/`Supavisor`, not a bare
#                        libpq session. That means this URL is capped by the
#                        project's session-mode pool_size (Project Settings >
#                        Database > Connection Pooling), NOT by Postgres's own
#                        max_connections. Every `new Pool()` anywhere in this
#                        codebase that points at THIS SAME URL draws from that
#                        one shared ceiling — the NestJS app pool
#                        (database.service.ts, max 10), the connect-pg-simple
#                        session store (main.ts), and this outbox cron (max 3)
#                        all compete for the same pool_size budget, and it gets
#                        worse with >1 Render web instance. We've hit
#                        `(EMAXCONNSESSION) max clients reached in session
#                        mode` in production from this. Before adding a new
#                        `Pool()` against SUPABASE_DB_URL: (1) always set an
#                        explicit `max` sized to actual concurrency need — never
#                        leave it uncapped, and (2) prefer routing short-lived,
#                        session-feature-free connections (no LISTEN/NOTIFY, no
#                        multi-statement advisory locks) through the
#                        transaction-mode pooler on port 6543 instead, since it
#                        multiplexes far more clients per pool_size slot.
# SUPABASE_DB_CA_CERT  — MEDIUM sensitivity (optional)
#                        PEM CA certificate for Postgres TLS verification when
#                        the provider's CA chain is not in Node's default trust
#                        store. Escaped \n sequences are supported.
# KAFKA_BROKERS        — MEDIUM sensitivity
#                        Comma-separated list of Kafka broker addresses.
#                        For Confluent / Upstash: use the public bootstrap URL.
#                        For local dev: localhost:9092
# KAFKA_SSL            — LOW sensitivity
#                        Set to 'true' when brokers require TLS (Confluent, Upstash).
# KAFKA_SASL_USERNAME  — MEDIUM sensitivity (omit if no SASL auth required)
# KAFKA_SASL_PASSWORD  — HIGH sensitivity  (omit if no SASL auth required)
# -----------------------------------------------------------------------------
SUPABASE_DB_URL=postgres://postgres:your-password@your-host.supabase.co:5432/postgres
# SUPABASE_DB_CA_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=false
# KAFKA_SASL_USERNAME=your-kafka-username
# KAFKA_SASL_PASSWORD=your-kafka-password

# =============================================================================
# Render deployment — environment variable instructions
# =============================================================================
#
# For Render deployments, configure runtime variables in Render Environment
# settings (do not commit a production .env file).
#
# Variables to configure in Render environment settings:
#
#   NODE_ENV                  = production
#   PORT                      = 4000
#   ENABLE_SWAGGER            = false
#   SUPABASE_URL              = https://your-project.supabase.co
#   SUPABASE_ANON_KEY         = <your anon key>
#   SUPABASE_SERVICE_ROLE_KEY = <your service role key>
#
#   GITHUB_CLIENT_ID          = <GitHub OAuth App client ID>
#   GITHUB_CLIENT_SECRET      = <GitHub OAuth App client secret>
#   GITHUB_CALLBACK_URL       = <public callback URL registered in GitHub OAuth App>
#
#   FRONTEND_URL              = <public frontend URL for OAuth redirects>
#   PLATFORM_PUBLIC_URL       = <public backend origin used by generated workflows>
#   TEMPLATE_REPO_PATH        = ../cicd-workflow
#   TEMPLATE_WORKFLOW_DIR     = workflow-templates
#
#   ALLOWED_ORIGINS — add exact frontend URL(s) for each environment.
#   Example:
#     https://test.example.com,https://uat.example.com,https://app.example.com
#   Do NOT use a bare wildcard (*) — the CORS factory enforces exact matching.
#
# Generated customer repositories receive per-slot Render deployment secrets:
#   RENDER_BACKEND_API_KEY
#   RENDER_BACKEND_SERVICE_ID
#   RENDER_BACKEND_OWNER_ID
#   RENDER_BACKEND_REGISTRY_CREDENTIAL_ID
#   RENDER_STANDALONE_API_KEY
#   RENDER_STANDALONE_SERVICE_ID
#   RENDER_STANDALONE_OWNER_ID
#   RENDER_STANDALONE_REGISTRY_CREDENTIAL_ID
#
# The central workflow builds and pushes a GHCR image, then calls:
#   POST /v1/services/{serviceId}/deploys
# with the pushed imageUrl.
# =============================================================================
