# =============================================================================
# Environment Variable Reference — Sensitivity Classification
# =============================================================================
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# Store HIGH-sensitivity values in GitHub Secrets / Vault / your cloud
# provider's secret manager — not in plaintext files on developer machines.
#
# Sensitivity levels used here:
#   LOW    — safe to log, share in tickets, or store unencrypted in CI env vars
#   MEDIUM — treat like a password: do not log, rotate on breach, but not a
#             root credential
#   HIGH   — treat like a private key: store in Vault/Secrets Manager, rotate
#             immediately on breach, never pass as a CLI argument or log
#
# =============================================================================

# -----------------------------------------------------------------------------
# Service identity
# NODE_ENV       — LOW sensitivity  
#                  Controls framework behaviour (error verbosity, Swagger, etc.)
#                  Values: development | test | production
# -----------------------------------------------------------------------------
NODE_ENV=development

# PORT           — LOW sensitivity
#                  TCP port the HTTP server binds to inside the container.
#                  The container port is remapped by the orchestrator; this
#                  value is not externally visible.
# -----------------------------------------------------------------------------
PORT=3000

# ENABLE_SWAGGER — LOW sensitivity
#                  Set to true ONLY in development/local environments.
#                  Swagger UI exposes full API schema — never enable in prod.
# -----------------------------------------------------------------------------
ENABLE_SWAGGER=false

# -----------------------------------------------------------------------------
# Supabase
# SUPABASE_URL              — LOW sensitivity
#                             Public HTTPS endpoint for your Supabase project.
#                             Visible in Supabase dashboard Settings > API.
# SUPABASE_ANON_KEY         — MEDIUM sensitivity
#                             JWT signed with the project's anon role. Safe for
#                             server-side use because RLS policies apply. Do not
#                             expose to end-user browsers from this service.
# SUPABASE_SERVICE_ROLE_KEY — HIGH sensitivity
#                             Bypasses all Row Level Security. Full database
#                             access with no restrictions. Store in Vault or
#                             GitHub Secrets — never in a .env file committed
#                             to any repository.
#
# Optional service-scoped Supabase clients for microservice/tribe routing:
#   <SERVICE>_SUPABASE_URL
#   <SERVICE>_SUPABASE_SECRET_KEY
# or
#   <SERVICE>_SUPABASE_SERVICE_ROLE_KEY
#
# Examples:
#   PAYMENT_SERVICE_SUPABASE_URL=https://payment-project.supabase.co
#   PAYMENT_SERVICE_SUPABASE_SECRET_KEY=payment-service-role-key
#   CHAT_SERVICE_SUPABASE_URL=https://chat-project.supabase.co
#   CHAT_SERVICE_SUPABASE_SECRET_KEY=chat-service-role-key
#
# Each scoped service must define both URL + secret key to be activated.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# CORS
# ALLOWED_ORIGINS — LOW sensitivity
#                   Comma-separated list of browser origins permitted to call
#                   this API. Example: http://localhost:5173,https://app.example.com
#                   No wildcard (*) is accepted — the CORS factory enforces
#                   exact-match whitelisting.
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# APICenter integration (optional for local dev — service starts without these
# but API-proxying features will be unavailable)
#
# API_CENTER_BASE_URL — LOW sensitivity
#                       Internal service URL for the APICenter gateway.
#                       Alias accepted: APICENTER_URL
#                       Example: https://apicenter.internal
# API_CENTER_TRIBE_ID  — MEDIUM sensitivity
#                       Alias accepted: APICENTER_TRIBE_ID
#                       Registered tribe/service id used for APICenter token issuance.
#                       Example: payment-service
# API_CENTER_TRIBE_SECRET — HIGH sensitivity
#                         Alias accepted: APICENTER_TRIBE_SECRET
#                         Shared secret used with API_CENTER_TRIBE_ID to mint
#                         short-lived APICenter access tokens.
# API_CENTER_API_KEY  — HIGH sensitivity
#                       Legacy static bearer token fallback only. Prefer tribe token flow
#                       (API_CENTER_TRIBE_ID + API_CENTER_TRIBE_SECRET) when possible.
# API_CENTER_TIMEOUT_MS — LOW sensitivity
#                         Alias accepted: APICENTER_TIMEOUT_MS
#                         HTTP timeout for APICenter requests in milliseconds.
#                         Default is 10000 when omitted.
# -----------------------------------------------------------------------------
API_CENTER_BASE_URL=https://apicenter.example.com
API_CENTER_TRIBE_ID=your-tribe-service-id
API_CENTER_TRIBE_SECRET=your-tribe-secret-here
API_CENTER_API_KEY=your-api-center-key-here
API_CENTER_TIMEOUT_MS=10000
# APICENTER_URL=https://apicenter.example.com
# APICENTER_TRIBE_ID=your-tribe-service-id
# APICENTER_TRIBE_SECRET=your-tribe-secret-here
# APICENTER_TIMEOUT_MS=10000

# -----------------------------------------------------------------------------
# Tribe self-registration (used by TribeRegistrationService on bootstrap)
#
# TRIBE_SERVICE_ID      — LOW sensitivity
#                         Overrides serviceId in tribe-manifest.json.
#                         Falls back to API_CENTER_TRIBE_ID, then the manifest value.
# TRIBE_NAME            — LOW sensitivity
#                         Human-readable service name sent to the registry.
# TRIBE_BASE_URL        — LOW sensitivity
#                         Reachable base URL of this service as seen by the platform.
# PLATFORM_ADMIN_SECRET — HIGH sensitivity
#                         Shared secret presented as X-Platform-Secret when
#                         self-registering with the API-Center registry endpoint.
#                         Store in Vault / GitHub Secrets — never commit the real value.
# -----------------------------------------------------------------------------
TRIBE_SERVICE_ID=template-tribe
TRIBE_NAME=Template Tribe Backend
TRIBE_BASE_URL=http://localhost:3001
PLATFORM_ADMIN_SECRET=change-me-in-production

# =============================================================================
# Render deployment — environment variable instructions
# =============================================================================
#
# For Render deployments, configure runtime variables in Render Environment
# settings (do not commit a production .env file).
# In production lanes, APICenter values are required so health verification can
# pass with checks.apiCenter=true.
#
# Variables to configure in Render environment settings:
#
#   NODE_ENV                  = production
#   PORT                      = 3000
#   ENABLE_SWAGGER            = false
#   SUPABASE_URL              = https://your-project.supabase.co
#   SUPABASE_ANON_KEY         = <your anon key>
#   SUPABASE_SERVICE_ROLE_KEY = <your service role key>
#   PAYMENT_SERVICE_SUPABASE_URL = https://payment-project.supabase.co
#   PAYMENT_SERVICE_SUPABASE_SECRET_KEY = <payment service role key>
#   CHAT_SERVICE_SUPABASE_URL = https://chat-project.supabase.co
#   CHAT_SERVICE_SUPABASE_SECRET_KEY = <chat service role key>
#   API_CENTER_BASE_URL       = <your APICenter URL>
#   API_CENTER_TRIBE_ID       = <your tribe service id>
#   API_CENTER_TRIBE_SECRET   = <your tribe secret>
#   API_CENTER_API_KEY        = <legacy static key; optional fallback>
#   API_CENTER_TIMEOUT_MS     = 10000
#
#   ALLOWED_ORIGINS — add exact frontend URL(s) for each environment.
#   Example:
#     https://test.example.com,https://uat.example.com,https://app.example.com
#   Do NOT use a bare wildcard (*) — the CORS factory enforces exact matching.
#
# The CI workflow uses Render deploy hooks and health endpoints from GitHub
# Secrets:
#   RENDER_DEPLOY_HOOK_URL_TEST / UAT / MAIN
#   RENDER_HEALTHCHECK_URL_TEST / UAT / MAIN
#   Optional fallback: RENDER_DEPLOY_HOOK_URL, RENDER_HEALTHCHECK_URL
# =============================================================================
